#Task 7
##Applying TBF on the server virtual machine with the following characteristics: rate 2.5Mbps, burst 20K, and limit the latency caused by the TBF to at most 50ms
sudo tc qdisc add dev enp0s3 root tbf rate 2.5mbit burst 20k latency 50ms
tc -s qdisc show dev enp0s3
##Running and iperf test on the client virtual machine 
iperf -c 192.168.56.101 -u -t 20 -w 256k

##Applying HTB on the server virtual machine with Guaranteed minimum bandwidth of 2.5Mbps, maximum bandwidth of the class is 5Mbps and burst length of 20k
sudo tc qdisc del dev enp0s3 root 2>/dev/null
sudo tc qdisc add dev enp0s3 root handle 1: htb default 10
sudo tc class add dev enp0s3 parent 1: classid 1:10 htb rate 2.5mbit ceil 5mbit burst 20k
##Running and iperf test on the client virtual machine 
iperf -c 192.168.56.101 -u -t 20 -w 256k

##Adding Traffic policing on the clients virtual machine that Applies dropping at 3.5 Mbps
sudo tc qdisc del dev enp0s3 ingress 2>/dev/null
sudo tc qdisc add dev enp0s3 handle ffff: ingres
sudo tc qdisc add dev enp0s3 handle ffff: ingress
sudo tc filter add dev enp0s3 parent ffff: protocol ip prio 1 u32 match u32 0 0 police rate 3.5mbit burst 10k drop flowid :1

##Running and iperf test on the client virtual machine 
iperf -c 192.168.56.101 -u -t 20 -w 256k
